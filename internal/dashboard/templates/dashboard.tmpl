{{/* Pizza Tracker dashboard regions, rendered server-side and streamed over SSE.
     html/template auto-escaping replaces the JS escapeHtml helper. */}}

{{- define "badge" -}}
<span class="vb {{versionClass .}}">{{.}}</span>
{{- end -}}

{{- define "order" -}}
<div class="order{{if .Failing}} fail{{end}}{{if .Done}} done{{end}}" id="order-{{.ID}}">
  <div class="oh">
    {{- template "badge" .Version -}}
    <b>#{{.ID}}</b>
    {{- if .Pizza}}<span class="nm">{{.Pizza}}</span>{{end -}}
    <span class="el">{{elapsed .ElapsedSec}}</span>
  </div>
  <div class="stepper" style="{{stepperStyle .}}">
    {{- range stepNodes . -}}
    <div class="node {{.Class}}"><div class="dot">{{.Glyph}}</div><div class="lbl">{{.Label}}</div></div>
    {{- end -}}
  </div>
</div>
{{- end -}}

{{- define "orders" -}}
{{- range .Orders}}{{template "order" .}}{{end -}}
{{- end -}}

{{- define "version" -}}
{{- /* . is a VersionCard */ -}}
<div class="ver{{if eq (printf "%s" .Status) "INACTIVE"}} inactive{{end}}">
  <div class="vrow">
    {{- template "badge" .Version -}}
    {{- if eq (printf "%s" .Status) "CURRENT"}}<span class="chip c-cur">CURRENT</span>
    {{- else if eq (printf "%s" .Status) "RAMPING"}}<span class="chip c-ramp">RAMPING {{.TrafficPct}}%</span>
    {{- else if eq (printf "%s" .Status) "DRAINING"}}<span class="chip c-drain">DRAINING</span>
    {{- else}}<span class="chip c-inact">INACTIVE</span>{{end -}}
  </div>
  <div class="bar"><span class="{{versionClass .Version}}" style="--bar-w:{{barWidth .TrafficPct}}%"></span></div>
  <div class="pin">{{.PinnedCount}} in flight</div>
</div>
{{- end -}}

{{- define "versions" -}}
{{- range .Versions -}}{{template "version" .}}{{end -}}
{{- end -}}

{{- define "controls" -}}
{{- /* . is a DashboardState. Rollback is disabled unless a version is ramping; Recover is disabled unless an order is failing. */ -}}
<button class="btn primary" type="button"
        hx-get="/api/deploy-modal" hx-target="#modal-host" hx-swap="innerHTML"
        hx-target-error="#toast">Deploy</button>
<button class="btn danger" type="button"
        hx-get="/api/rollback-modal" hx-target="#modal-host" hx-swap="innerHTML"
        hx-target-error="#toast"{{if not (hasRamping .Versions)}} disabled{{end}}>Rollback</button>
<button class="btn recover" type="button"
        hx-post="/api/recover" hx-target="#toast" hx-swap="innerHTML" hx-target-error="#toast"{{if not (hasFailing .Orders)}} disabled{{end}}>Recover</button>
{{- end -}}

{{- define "toast" -}}
<div class="toast show">{{.Message}}</div>
{{- end -}}

{{- define "deploy-modal" -}}
<div class="modal-scrim" hx-get="/api/close" hx-target="#modal-host" hx-swap="innerHTML"
     hx-trigger="keyup[key=='Escape'] from:body">
  <form class="modal" role="dialog" aria-modal="true" aria-label="Deploy a version"
        hx-post="/api/deploy" hx-target="#modal-host" hx-swap="innerHTML" hx-target-error="#toast">
    <h3>Deploy</h3>
    <div class="modal-lbl">Target version</div>
    <div class="radios">
      {{- range .Versions}}
      <label class="radio">
        <input type="radio" name="version" value="{{.Version}}"{{if .Checked}} checked{{end}}
               hx-get="/api/deploy-ramp" hx-target="#deploy-ramp" hx-swap="outerHTML" />
        <span class="vb {{versionClass .Version}}">{{.Version}}</span>
      </label>
      {{- end}}
    </div>
    {{- template "deploy-ramp" .Ramp -}}
    <p class="modal-note">At 100% this promotes the version to Current.</p>
    <div class="modal-acts">
      <button class="btn" type="button" hx-get="/api/close" hx-target="#modal-host" hx-swap="innerHTML">Cancel</button>
      <button class="btn primary" type="submit">Apply</button>
    </div>
  </form>
</div>
{{- end -}}

{{- define "deploy-ramp" -}}
<div id="deploy-ramp">
  <div class="modal-lbl">Ramping <span class="pct">{{.Pct}}%</span></div>
  <input class="stepper-range" type="range" name="stop" min="0" max="3" step="1" value="{{.StopIdx}}"
         list="deploy-stops"
         hx-get="/api/deploy-ramp" hx-trigger="change" hx-include="input[name='version']:checked"
         hx-target="#deploy-ramp" hx-swap="outerHTML" />
  <datalist id="deploy-stops">
    <option value="0"></option>
    <option value="1"></option>
    <option value="2"></option>
    <option value="3"></option>
  </datalist>
</div>
{{- end -}}

{{- define "rollback-modal" -}}
<div class="modal-scrim" hx-get="/api/close" hx-target="#modal-host" hx-swap="innerHTML"
     hx-trigger="keyup[key=='Escape'] from:body">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Confirm rollback">
    <h3>Roll back?</h3>
    <p class="modal-note">This reverts traffic to the previously Current version.</p>
    <div class="modal-acts">
      <button class="btn" type="button" hx-get="/api/close" hx-target="#modal-host" hx-swap="innerHTML">Cancel</button>
      <button class="btn danger" type="button"
              hx-post="/api/rollback" hx-target="#modal-host" hx-swap="innerHTML" hx-target-error="#toast">Roll back</button>
    </div>
  </div>
</div>
{{- end -}}
