{{/* Pizza Tracker dashboard regions, rendered server-side and streamed over SSE.
     html/template auto-escaping replaces the JS escapeHtml helper. */}}

{{- define "badge" -}}
<span class="vb {{versionClass .}}">{{.}}</span>
{{- end -}}

{{- define "order" -}}
<div class="order{{if .Failing}} fail{{end}}{{if .Done}} done{{end}}" id="order-{{.ID}}">
  <div class="oh">
    {{- template "badge" .Version -}}
    <b>#{{.ID}}</b>
    {{- if .Pizza}}<span class="nm">{{.Pizza}}</span>{{end -}}
    <span class="el">{{elapsed .ElapsedSec}}</span>
  </div>
  <div class="stepper" style="{{stepperStyle .}}">
    {{- range stepNodes . -}}
    <div class="node {{.Class}}"><div class="dot">{{.Glyph}}</div><div class="lbl">{{.Label}}</div></div>
    {{- end -}}
  </div>
</div>
{{- end -}}

{{- define "orders" -}}
{{- range .Orders}}{{template "order" .}}{{end -}}
{{- end -}}

{{- define "version" -}}
{{- /* . is a VersionCard */ -}}
<div class="ver{{if eq (printf "%s" .Status) "INACTIVE"}} inactive{{end}}">
  <div class="vrow">
    {{- template "badge" .Version -}}
    {{- if eq (printf "%s" .Status) "CURRENT"}}<span class="chip c-cur">CURRENT</span>
    {{- else if eq (printf "%s" .Status) "RAMPING"}}<span class="chip c-ramp">RAMPING {{.TrafficPct}}%</span>
    {{- else if eq (printf "%s" .Status) "DRAINING"}}<span class="chip c-drain">DRAINING</span>
    {{- else}}<span class="chip c-inact">INACTIVE</span>{{end -}}
  </div>
  <div class="bar"><span class="{{versionClass .Version}}" style="--bar-w:{{barWidth .TrafficPct}}%"></span></div>
  <div class="pin">{{.PinnedCount}} in flight</div>
</div>
{{- end -}}

{{- define "versions" -}}
{{- range .Versions -}}{{template "version" .}}{{end -}}
{{- end -}}

{{- define "toast" -}}
<div class="toast show">{{.Message}}</div>
{{- end -}}
