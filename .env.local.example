# Local-dev overlay for the Make targets.
#
# Copy this file to `.env.local` (gitignored). It is loaded ONLY by the
# local-dev Make targets (dev, backend, worker*, app-*, infra-*, test,
# check). The deploy/teardown targets ignore it and run against the host
# environment unchanged.

# Temporal frontend gRPC address.
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace.
TEMPORAL_NAMESPACE=default

# Worker Deployment name. Shared by the worker (TEMPORAL_DEPLOYMENT_NAME)
# and the backend (PIZZA_DEPLOYMENT_NAME).
# DEPLOYMENT_NAME=default.pizza

# Task queue polled by the worker and used to start orders.
# PIZZA_TASK_QUEUE=pizza
